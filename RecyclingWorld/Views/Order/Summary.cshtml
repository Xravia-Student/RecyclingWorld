@model RecyclingWorld.ViewModels.OrderSummaryViewModel
@{
    ViewData["Title"] = "Order Summary";
}

<h1 class="mb-4">Order Summary</h1>

<div class="row">
    <div class="col-md-6">
        <h4>Items</h4>
        <table class="table">
            <thead><tr><th>Material</th><th>Qty (kg)</th><th>Price/kg</th><th>Total</th></tr></thead>
            <tbody>
                @foreach (var item in Model.CartItems)
                {
                    <tr>
                        <td>@item.Title</td>
                        <td>@item.Quantity</td>
                        <td>$@item.PricePerKg</td>
                        <td>$@(item.PricePerKg * (decimal)item.Quantity)</td>
                    </tr>
                }
            </tbody>
            <tfoot><tr><th colspan="3" class="text-end">Total:</th><th>$@Model.OrderTotal</th></tr></tfoot>
        </table>
    </div>

    <div class="col-md-6">
        <h4>Shipping Address</h4>
        <form asp-action="PlaceOrder" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-2">
                <label asp-for="Order.Name" class="form-label">Name</label>
                <input asp-for="Order.Name" class="form-control" />
            </div>
            <div class="mb-2">
                <label asp-for="Order.StreetAddress" class="form-label">Street Address</label>
                <input asp-for="Order.StreetAddress" class="form-control" />
            </div>
            <div class="mb-2">
                <label asp-for="Order.City" class="form-label">City</label>
                <input asp-for="Order.City" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="Order.PostalCode" class="form-label">Postal Code</label>
                <input asp-for="Order.PostalCode" class="form-control" />
            </div>
            <button type="submit" class="btn btn-success">Place Order</button>
        </form>
    </div>
</div>

