@model List<RecyclingWorld.Models.Order>
@{
    ViewData["Title"] = "My Orders";
}

<h1 class="mb-4">My Orders</h1>

@if (!Model.Any())
{
    <p>You have no orders yet.</p>
}
else
{
    <table class="table">
        <thead><tr><th>Order #</th><th>Date</th><th>Total</th><th>Payment</th><th>Tracking</th><th>Shipment</th></tr></thead>
        <tbody>
            @foreach (var o in Model)
            {
                <tr>
                    <td>@o.Id</td>
                    <td>@o.OrderDate.ToShortDateString()</td>
                    <td>$@o.OrderTotal</td>
                    <td>
                        <span class="badge @(o.PaymentStatus == "Paid" ? "bg-success" : "bg-warning text-dark")"> 
                            @o.PaymentStatus
                        </span>
                    </td>
                    <td>@o.Shipment?.TrackingNumber</td>
                    <td>
                        <span class="badge bg-info text-dark">@o.Shipment?.ShippingStatus</span>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}


